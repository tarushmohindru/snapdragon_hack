FORMFUSION_ENVIRONMENT=development
FORMFUSION_ALLOWED_ORIGINS=["http://localhost:3000"]
FORMFUSION_SESSION_TTL_SECONDS=7200
FORMFUSION_MAX_DEVICES_PER_SESSION=2
FORMFUSION_FRAME_QUEUE_CAPACITY=12
FORMFUSION_FRAME_SYNC_TOLERANCE_MS=60
FORMFUSION_MAX_CALIBRATION_IMAGE_BYTES=10485760
FORMFUSION_ML_SERVICE_URL=http://127.0.0.1:8100
FORMFUSION_ML_SERVICE_KEY=local-ml-service-key-change-before-production
FORMFUSION_JOIN_CODE_SECRET=local-join-code-secret-change-before-production
FORMFUSION_DATABASE_PATH=.data/formfusion.sqlite3
FORMFUSION_DATABASE_PATH=.data/formfusion.sqlite3
